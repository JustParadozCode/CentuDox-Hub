

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

local LocalPlayer = Players.LocalPlayer
local gui = gethui() 

-- Create Background Blur
local blurEffect = Instance.new("BlurEffect")
blurEffect.Size = 20
blurEffect.Parent = Lighting

-- Create the ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "CentudoxMaintenance"
screenGui.ResetOnSpawn = false
screenGui.Parent = gui

-- Main Cyber Panel Frame
local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, 440, 0, 260)
MainFrame.Position = UDim2.new(0.5, -220, 0.5, -130)
MainFrame.BackgroundColor3 = Color3.fromRGB(10, 16, 26) 
MainFrame.BackgroundTransparency = 0.25
MainFrame.BorderSizePixel = 0
MainFrame.Parent = screenGui

-- Rounded Corners for Panel
local FrameCorner = Instance.new("UICorner")
FrameCorner.CornerRadius = UDim.new(0, 14)
FrameCorner.Parent = MainFrame

-- Cool Pacific Blue Neon Gradient Border
local UIStroke = Instance.new("UIStroke")
UIStroke.Thickness = 2.5
UIStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
UIStroke.Parent = MainFrame

local BorderGradient = Instance.new("UIGradient")
BorderGradient.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 190, 255)),   
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 240, 255)), 
    ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 115, 230))    
}
BorderGradient.Rotation = 45
BorderGradient.Parent = UIStroke

-- Script Title
local Title = Instance.new("TextLabel")
Title.Name = "Title"
Title.Size = UDim2.new(1, 0, 0, 45)
Title.Position = UDim2.new(0, 0, 0, 10)
Title.BackgroundTransparency = 1
Title.Text = "Centudox | Aimbot | Blox Fruits"
Title.TextColor3 = Color3.fromRGB(240, 248, 255)
Title.TextSize = 24
Title.Font = Enum.Font.Michroma 
Title.Parent = MainFrame


local Divider = Instance.new("Frame")
Divider.Name = "Divider"
Divider.Size = UDim2.new(0.9, 0, 0, 1)
Divider.Position = UDim2.new(0.05, 0, 0, 60)
Divider.BackgroundColor3 = Color3.fromRGB(0, 210, 255)
Divider.BackgroundTransparency = 0.5
Divider.BorderSizePixel = 0
Divider.Parent = MainFrame


local Message = Instance.new("TextLabel")
Message.Name = "Message"
Message.Size = UDim2.new(0.9, 0, 0, 100)
Message.Position = UDim2.new(0.05, 0, 0, 70)
Message.BackgroundTransparency = 1
Message.Text = "The script is down for maintenance or has been outdated\n\nJoin discord for more updates\n<font color='rgb(0, 210, 255)'>https://discord.gg/centu-sherman-1348168772862869514</font>"
Message.TextColor3 = Color3.fromRGB(195, 210, 225)
Message.TextSize = 15
Message.Font = Enum.Font.SourceSans
Message.TextWrapped = true
Message.RichText = true -- Renders the custom Pacific Blue color tag for the Discord link
Message.Parent = MainFrame


local exitButton = Instance.new("TextButton")
exitButton.Name = "ExitButton"
exitButton.Text = "Exit Game"
exitButton.Size = UDim2.new(0.9, 0, 0, 42)
exitButton.Position = UDim2.new(0.05, 0, 1, -55)
exitButton.BackgroundColor3 = Color3.fromRGB(12, 35, 64) -- Deep blue base button
exitButton.TextColor3 = Color3.fromRGB(255, 255, 255)
exitButton.Font = Enum.Font.SourceSansBold
exitButton.TextSize = 18
exitButton.AutoButtonColor = true
exitButton.Parent = MainFrame

local cornerRadius = Instance.new("UICorner")
cornerRadius.CornerRadius = UDim.new(0, 8)
cornerRadius.Parent = exitButton


local ButtonGradient = Instance.new("UIGradient")
ButtonGradient.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 90, 180)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(5, 40, 85))
}
ButtonGradient.Rotation = 90
ButtonGradient.Parent = exitButton

-- Function to exit the game cleanly with a fadeout
local function exitGame()
    -- Smoothly fade elements out before execution
    TweenService:Create(MainFrame, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
    TweenService:Create(Title, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
    TweenService:Create(Message, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
    TweenService:Create(exitButton, TweenInfo.new(0.2), {TextTransparency = 1, BackgroundTransparency = 1}):Play()
    TweenService:Create(blurEffect, TweenInfo.new(0.2), {Size = 0}):Play()
    
    task.wait(0.2)
    game:Shutdown()
end

exitButton.MouseButton1Click:Connect(exitGame)
